<Page x:Class="Практическая_работа_4_Кузнецов_Кузьмин.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Page1" Height="450" Width="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Grid.Row="0" Grid.ColumnSpan="2" Source="C:\Users\bosss\source\repos\Практическая работа 4 Кузнецов_Кузьмин\Практическая работа 4 Кузнецов_Кузьмин\Images\Page1.png" MaxHeight="150" Margin="5" Stretch="Uniform"/>

        <Label Grid.Row="1" Grid.Column="0" Content="X:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="XTextBox" Grid.Row="1" Grid.Column="1" Margin="5" Padding="3" 
                 ToolTip="Введите любое число" ToolTipService.InitialShowDelay="0"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Y:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="YTextBox" Grid.Row="2" Grid.Column="1" Margin="5" Padding="3" 
                 MouseEnter="YTextBox_MouseEnter" ToolTipService.InitialShowDelay="0"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Z:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="ZTextBox" Grid.Row="3" Grid.Column="1" Margin="5" Padding="3" 
                 MouseEnter="ZTextBox_MouseEnter" ToolTipService.InitialShowDelay="0"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Результат β:" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="ResultTextBox" Grid.Row="4" Grid.Column="1" Margin="5" Padding="3" IsReadOnly="True" Background="LightGray"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
            <Button x:Name="CalculateButton" Content="Вычислить" Width="100" Height="30" Margin="5" Click="CalculateButton_Click"/>
            <Button x:Name="ClearButton" Content="Очистить" Width="100" Height="30" Margin="5" Click="ClearButton_Click"/>
            <Button x:Name="NextPageButton" Content="Далее →" Width="100" Height="30" Margin="5" Click="NextPageButton_Click"/>
        </StackPanel>
    </Grid>
</Page>